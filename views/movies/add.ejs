<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <!-- Page Header -->
     
    <main>

        <section class="content card-container">
            <a href="/movies" class="primary-color" id="goback-btn"> ⮜ Back to Movies</a>
            
            <form method="POST" action="/movies">
                <div class="page-header">
                    <div class="page-heading">
                        <h1>Add New Movie</h1>
                        <p>Fill in the details below to add a new movie to the collection.</p>
                    </div>
                </div>
                <%- include('./partials/movie-form', {movie:{}, genres, languages, ageRatings}) %>

                <section class="form-actions">
                    <a href="/movies" class="secondary-btn">Cancel</a>
                    <button type="submit" class="primary-btn">Add Movie</button>
                </section>

            </form>

        </section>

    </main>
    
</body>
</html>