<div id="form-container">

    <section class="form-section" id="basic-info-section">
        <fieldset>
            <legend>1. Basic Information</legend>
            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" name="title" id="title"  placeholder="Enter movie title" maxlength="100" value="<%= movie.title || ''  %>" required>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea 
                    name="description" 
                    id="description" 
                    placeholder="Enter movie description" 
                    minlength="10" 
                    maxlength="600" 
                    rows="8" 
                    required 
                ><%= movie.description || ''  %></textarea>
            </div>

            <div class="form-group">
                <label>Genres</label>
                <div class="checkbox-group">
                    <% genres.forEach(genre => {%>
                        <div class="form-group checkbox-field">

                            <input 
                                type="checkbox"
                                name="genre"
                                id="genre-<%= genre._id %>"
                                value="<%= genre._id  %>"
                                <%= movie.genre && movie.genre.some(g => g._id.equals(genre._id) )? 'checked' : '' %>
                            >
                            <label for="genre-<%= genre._id %>"><%=genre.name%></label>
                        </div>
                    <%}); %>
                </div>      
            </div>
        </fieldset>
    </section>

    <section class="form-section" id="form-details-section">
        <fieldset>
            <legend>2. Movie Details</legend>
            <div class="field-grid">
                <div class="form-group">
                    <label for="movie-duration">Duration (minutes)</label>
                    <input type="number" name="duration" id="movie-duration" min="15" placeholder="e.g. 120"  value="<%= movie.duration || '' %>" required>
                </div>
                <div class="form-group">
                    <label for="movie-release-date">Release Date</label>
                    <input 
                        type="date"
                        name="releaseDate" 
                        id="movie-release-date" 
                        value="<%= movie.releaseDate ? movie.releaseDate.toISOString().split('T')[0] : '' %>" 
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="movie-language">Language</label>
                    <select name="language" id="movie-language" required>

                        <option
                            class="dropdown-placeholder" 
                            value="" 
                            <%= !movie.language ? 'selected' : '' %>
                            disabled
                        >Select language</option>

                        <% languages.forEach(language => {%>
                            <option  
                                value="<%= language %>"  
                                <%= movie.language === language ? 'selected' : '' %>
                            >
                                <%= language %>
                            </option>
                        <%}) %>

                    </select>
                    
                </div>
                <div class="form-group">
                    <label for="movie-ageRating">Age Rating</label>
                    <select name="ageRating" id="movie-ageRating" required>
                        
                        <option 
                            class="dropdown-placeholder" 
                            value=""
                            <%= !movie.ageRating ? 'selected' : '' %> 
                            disabled
                        >Select age rating</option>
                        
                        <% ageRatings.forEach(rate=>{%>
                            <option  
                                value="<%= rate %>"
                                <%= movie.ageRating === rate ? 'selected' : '' %>
                            >
                                <%= rate %>
                            </option>
                            <%}) %>
                            
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="movie-status">Status</label>
                        <select name="status" id="movie-status" required>
                            <option 
                                class="dropdown-placeholder" 
                                value=""  
                                <%= !movie.status ? 'selected' : '' %>
                                disabled
                            >Select status</option>
                            <option value="Now Showing" <%= movie.status === "Now Showing" ? 'selected' : '' %>>Now Showing</option>
                            <option value="Coming Soon" <%= movie.status === "Coming Soon" ? 'selected' : '' %>>Coming Soon</option>
                        </select>
                    </div>
                </div>
        </fieldset>
    </section>
    


    <section class="form-section" id="form-media-section">
        <fieldset>
            <legend>3. Media</legend>
            <div class="form-group">
                <label for="movie-poster-url">Poster URL</label>
                <input 
                    type="url" 
                    name="posterUrl" 
                    id="movie-poster-url" 
                    placeholder="https://example.com/poster.jpg"
                    value="<%= movie.posterUrl || ''%>"
                    required
                >
            </div>
            <div class="form-group">
                <label for="movie-trailer-url">Trailer URL</label>
                <input 
                    type="url" 
                    name="trailerUrl" 
                    id="movie-trailer-url" 
                    placeholder="https://www.youtube.com/watch?v=..."
                    value="<%= movie.trailerUrl || '' %>" 
                    required
                >
            </div>
        </fieldset>


    </section>            

    <section class="form-section" id="form-highlights-section">
        <fieldset>
            <legend>4. Highlights</legend>
            <div class="checkbox-group form-group">
                <div class="checkbox-field">
                    <input 
                        type="checkbox" 
                        name="isTrending" 
                        id="movie-trending-checkbox"
                        <%= movie.isTrending ? 'checked' : '' %>
                    >
                    <label for="movie-trending-checkbox">Trending Movie</label>
                </div>

                <div class="checkbox-field">
                    <input 
                        type="checkbox" 
                        name="isFeatured" 
                        id="movie-featured-checkbox"
                        <%= movie.isFeatured ? 'checked' : '' %>
                    >
                    <label for="movie-featured-checkbox">Featured Movie</label>
                </div>
            </div>
        </fieldset>


    </section>            

</div>
        



